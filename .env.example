# Near-Craft Environment Variables Template
# Copy this file to '.env' and fill in your actual values.
# DO NOT commit the '.env' file to your version control.

# ==========================================
# 1. Supabase Configuration (Required)
# ==========================================
# Get these from your Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key

# ==========================================
# 2. Stripe Configuration (Optional)
# ==========================================
# Required only if you are testing or implementing Stripe-based payment flows
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==========================================
# 3. Google Gemini Configuration (Optional)
# ==========================================
# Required for AI-based price suggestions and feature estimation
GEMINI_API_KEY=your_gemini_api_key
